# ============================================================
#  .env.example  —  Environment Variables Template
#  ✅ SAFE TO COMMIT — contains no real values
#
#  HOW TO USE:
#    1. Copy this file: cp .env.example .env
#    2. Fill in your real credentials in .env
#    3. Upload .env to your server — never commit it to Git
# ============================================================

# ── Cashfree Credentials ─────────────────────────────────────
CF_APP_ID=YOUR_CASHFREE_APP_ID
CF_SECRET_KEY=YOUR_CASHFREE_SECRET_KEY

# ── Environment: sandbox | production ────────────────────────
CF_ENV=sandbox

# ── App URL (no trailing slash) ───────────────────────────────
APP_BASE_URL=http://localhost/project/Appointmentbooking

# ── Consultation Fee (INR) ────────────────────────────────────
CONSULTATION_FEE=100

# ── Database Credentials ──────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=appointment_db
